+static uint16_t whisper_f32_to_f16_bits(float value) {
+    __fp16 half = (__fp16) value;
+    uint16_t bits;
+    memcpy(&bits, &half, sizeof(bits));
+    return bits;
+}
+
+static float whisper_f16_bits_to_f32(uint16_t bits) {
+    __fp16 half;
+    memcpy(&half, &bits, sizeof(half));
+    return (float) half;
+}
